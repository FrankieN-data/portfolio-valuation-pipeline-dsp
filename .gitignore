# ================================================================
# Databricks .gitignore
# ================================================================

# Databricks notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Delta Lake transaction logs and metadata
_delta_log/
*/_delta_log/*

# Pipeline metadata and state
.pipeline/
*/.pipeline/*

# Spark local directories
spark-warehouse/
metastore_db/
derby.log

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/

# IDE specific files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter Notebook
.ipynb_checkpoints

# Environment variables
.env
.env.local

# Databricks CLI config (contains tokens)
.databrickscfg

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
.cache/

# Data files (exclude actual data from version control)
*.parquet
*.csv
*.json
*.avro
*.orc
# Exception: Keep sample/test data if needed
# !sample_data/*.parquet

# Compiled files
*.class
*.jar

# OS generated files
Thumbs.db
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Databricks Asset Bundles (DABs)
# Uncomment if you want to exclude DABs state
# .databricks/

# Test coverage
htmlcov/
.tox/
.coverage
.coverage.*
.pytest_cache/
nosetests.xml
coverage.xml
*.cover

# Documentation build
docs/_build/

# ================================================================
# Project specific exclusions
# ================================================================

# Exclude exploration notebooks with sensitive data
explorations/scratch_*.ipynb
explorations/temp_*.py

# Exclude large result files
_resources/*.parquet
_resources/*.csv
